# Supabase — get these from your project at https://supabase.com/dashboard
# Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER-SIDE ONLY. Never expose to the browser.
# Used for privileged operations (admin actions, role changes).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for auth redirects). In production set to your domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
